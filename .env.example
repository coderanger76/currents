# Copy this file to .env and fill in your keys, or export them in your shell profile.
#
# Add to ~/.zshrc:
#   export NYT_API_KEY=your_key_here
#   (etc.)

# NY Times API — https://developer.nytimes.com/get-started
NYT_API_KEY=your_nyt_api_key_here

# Federal Reserve / FRED API — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# NASA API — https://api.nasa.gov/ (DEMO_KEY works with rate limits)
NASA_API_KEY=your_nasa_api_key_here

# OpenWeatherMap API — https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here
